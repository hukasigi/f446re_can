  97:Core/Src/main.c **** void CAN_TX_MOTOR(int16_t m1, int16_t m2, int16_t m3, int16_t m4) {
  98:Core/Src/main.c ****     static CAN_TxHeaderTypeDef TxHeader = {.StdId              = 0x200,
  99:Core/Src/main.c ****                                            .RTR                = CAN_RTR_DATA,
 100:Core/Src/main.c ****                                            .IDE                = CAN_ID_STD,
 101:Core/Src/main.c ****                                            .DLC                = 8,
 102:Core/Src/main.c ****                                            .TransmitGlobalTime = DISABLE};
 103:Core/Src/main.c **** 
 104:Core/Src/main.c ****     uint32_t TxMailbox;
 105:Core/Src/main.c ****     uint8_t  TxData[8] = {0};
 106:Core/Src/main.c **** 
 107:Core/Src/main.c ****     TxData[0] = (uint8_t)(m1 >> 8);
 108:Core/Src/main.c ****     TxData[1] = (uint8_t)(m1);
 109:Core/Src/main.c ****     TxData[2] = (uint8_t)(m2 >> 8);
 110:Core/Src/main.c ****     TxData[3] = (uint8_t)(m2);
 111:Core/Src/main.c ****     TxData[4] = (uint8_t)(m3 >> 8);
 112:Core/Src/main.c ****     TxData[5] = (uint8_t)(m3);
 113:Core/Src/main.c ****     TxData[6] = (uint8_t)(m4 >> 8);
 114:Core/Src/main.c ****     TxData[7] = (uint8_t)(m4);
 115:Core/Src/main.c **** 
 116:Core/Src/main.c ****     if (HAL_CAN_GetTxMailboxesFreeLevel(&hcan1) > 0) {
 117:Core/Src/main.c ****         if (HAL_CAN_AddTxMessage(&hcan1, &TxHeader, TxData, &TxMailbox) != HAL_OK) {
 118:Core/Src/main.c ****             Error_Handler();
 119:Core/Src/main.c ****         }
 120:Core/Src/main.c ****     }
 121:Core/Src/main.c **** }
