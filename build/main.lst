 123:Core/Src/main.c **** void HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef* hcan1) {
 124:Core/Src/main.c ****     CAN_RxHeaderTypeDef RxHeader;  // ÕÅŚõ┐ĪŃāĪŃāāŃé╗Ńā╝ŃéĖŃü«µāģÕĀ▒ŃüīµĀ╝ń┤ŹŃüĢŃéīŃéŗŃéżŃā│Ńé╣Ńé┐Ń
 125:Core/Src/main.c ****     uint8_t             RxData[8]; // ÕÅŚõ┐ĪŃüŚŃü¤ŃāćŃā╝Ńé┐ŃéÆõĖĆµÖéõ┐ØÕŁśŃüÖŃéŗķģŹÕłŚ
 126:Core/Src/main.c ****     if (HAL_CAN_GetRxMessage(hcan1, CAN_RX_FIFO0, &RxHeader, RxData) == HAL_OK) {
 127:Core/Src/main.c ****         uint32_t id = RxHeader.StdId; // RxHeaderŃü«õĖŁŃü½ÕģźŃüŻŃü”ŃüäŃéŗidŃéÆÕÅ¢ŃéŖÕć║ŃüÖ
 128:Core/Src/main.c ****         if (id >= 0x201 && id <= 0x204) {
 129:Core/Src/main.c ****             int index = id - 0x201; // 0ŃĆ£3Ńü½ÕżēµÅø
 130:Core/Src/main.c ****             for (int i = 0; i < 8; i++) {
